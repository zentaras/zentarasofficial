generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  imageUrl  String?  @map("image_url")
  username  String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  aiResumeScreenerApps   AiResumeScreenerApplicant[]
  ecommerceAnalyticsApps EcommerceAnalyticsApplicant[]
  sentimentDashboardApps SentimentDashboardApplicant[]
  internshipTracks       InternshipTrack[]

  @@map("users")
}

model AiResumeScreenerApplicant {
  id              String    @id @default(cuid())
  clerkUserId     String?   @map("clerk_user_id")
  user            User?     @relation(fields: [clerkUserId], references: [clerkId])
  fullName        String    @map("full_name")
  email           String
  phone           String?
  college         String
  branch          String
  graduationYear  String    @map("graduation_year")
  cgpa            String?
  linkedinUrl     String?   @map("linkedin_url")
  githubUrl       String?   @map("github_url")
  resumeLink      String    @map("resume_link")
  whyInterested   String    @map("why_interested") @db.Text
  priorExperience String    @map("prior_experience") @db.Text
  toolsKnown      String    @map("tools_known")
  availability    String
  startDate       String    @map("start_date")
  status          String    @default("Pending")
  adminNote       String?   @map("admin_note") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@index([clerkUserId])
  @@map("ai_resume_screener_applicants")
}

model EcommerceAnalyticsApplicant {
  id              String    @id @default(cuid())
  clerkUserId     String?   @map("clerk_user_id")
  user            User?     @relation(fields: [clerkUserId], references: [clerkId])
  fullName        String    @map("full_name")
  email           String
  phone           String?
  college         String
  branch          String
  graduationYear  String    @map("graduation_year")
  cgpa            String?
  linkedinUrl     String?   @map("linkedin_url")
  githubUrl       String?   @map("github_url")
  resumeLink      String    @map("resume_link")
  whyInterested   String    @map("why_interested") @db.Text
  priorExperience String    @map("prior_experience") @db.Text
  toolsKnown      String    @map("tools_known")
  projectLink     String?   @map("project_link")
  availability    String
  startDate       String    @map("start_date")
  status          String    @default("Pending")
  adminNote       String?   @map("admin_note") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@index([clerkUserId])
  @@map("ecommerce_analytics_applicants")
}

model SentimentDashboardApplicant {
  id              String    @id @default(cuid())
  clerkUserId     String?   @map("clerk_user_id")
  user            User?     @relation(fields: [clerkUserId], references: [clerkId])
  fullName        String    @map("full_name")
  email           String
  phone           String?
  college         String
  branch          String
  graduationYear  String    @map("graduation_year")
  cgpa            String?
  linkedinUrl     String?   @map("linkedin_url")
  githubUrl       String?   @map("github_url")
  resumeLink      String    @map("resume_link")
  whyInterested   String    @map("why_interested") @db.Text
  priorExperience String    @map("prior_experience") @db.Text
  toolsKnown      String    @map("tools_known")
  nlpExperience   String    @map("nlp_experience") @db.Text
  availability    String
  startDate       String    @map("start_date")
  status          String    @default("Pending")
  adminNote       String?   @map("admin_note") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@index([clerkUserId])
  @@map("sentiment_dashboard_applicants")
}

// ── Internship Tracking ───────────────────────────────────────────────────────

model InternshipTrack {
  id          String    @id @default(cuid())
  clerkUserId String    @map("clerk_user_id")
  user        User      @relation(fields: [clerkUserId], references: [clerkId])

  projectKey  String    @map("project_key")
  projectName String    @map("project_name")
  applicantId String    @map("applicant_id")

  currentStep Int       @default(1) @map("current_step")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")

  // ── Admin evaluation fields (filled when completing Step 5) ──────────────
  // Rating: "Excellent" | "Good" | "Average" | "Needs Improvement"
  performanceRating  String?  @map("performance_rating")
  overallFeedback    String?  @map("overall_feedback") @db.Text
  certificateLink    String?  @map("certificate_link")
  lorLink            String?  @map("lor_link")           // Letter of Recommendation
  projectRepoLink    String?  @map("project_repo_link")  // Final project repo shared by admin
  evaluationNotes    String?  @map("evaluation_notes") @db.Text // Internal admin notes (not shown to candidate)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  steps       InternshipStep[]

  @@unique([clerkUserId, applicantId])
  @@index([clerkUserId])
  @@index([projectKey])
  @@map("internship_tracks")
}

model InternshipStep {
  id         String          @id @default(cuid())
  trackId    String          @map("track_id")
  track      InternshipTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  stepNumber Int     @map("step_number")
  stepTitle  String  @map("step_title")

  // "pending" | "submitted" | "approved" | "rejected"
  status     String  @default("pending")

  data       Json?

  adminNote  String?   @map("admin_note") @db.Text
  reviewedAt DateTime? @map("reviewed_at")
  reviewedBy String?   @map("reviewed_by")

  deadline    DateTime? @map("deadline")
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([trackId, stepNumber])
  @@index([trackId])
  @@index([status])
  @@map("internship_steps")
}
