generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id
  email          String?          @unique
  createdAt      DateTime         @default(now()) @map("created_at")
  applications   Application[]
  resumeAnalyses ResumeAnalysis[]
  resumeUsage    ResumeUsage?

  @@map("users")
}

model Application {
  id               String    @id @default(cuid())
  clerkUserId      String    @map("clerk_user_id")
  user             User      @relation(fields: [clerkUserId], references: [id])
  company          String
  role             String
  jobType          String    @default("Job") @map("job_type")
  applyType        String    @default("Direct Apply") @map("apply_type")
  platform         String?
  jobLink          String?   @map("job_link")
  dateApplied      DateTime? @map("date_applied") @db.Date
  status           String    @default("Applied")
  workType         String    @default("Onsite") @map("work_type")
  priority         String    @default("Medium")
  recruiterName    String?   @map("recruiter_name")
  recruiterContact String?   @map("recruiter_contact")
  followUpDate     DateTime? @map("follow_up_date") @db.Date  // ← indexed now
  salary           String?
  resumeVersion    String?   @map("resume_version")
  attachmentLink   String?   @map("attachment_link")
  notes            String?
  statusHistory    Json      @default("[]") @map("status_history")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([clerkUserId])
  @@index([clerkUserId, status])
  @@index([clerkUserId, followUpDate])    // ← NEW: "show me due follow-ups"
  @@index([clerkUserId, dateApplied])     // ← NEW: "apps from last 30 days"
  @@index([clerkUserId, createdAt])       // ← NEW: dashboard timeline sort
  @@map("applications")
}

model ResumeAnalysis {
  id            String   @id @default(cuid())
  clerkUserId   String   @map("clerk_user_id")
  user          User     @relation(fields: [clerkUserId], references: [id])
  resumeVersion String?  @map("resume_version")
  matchScore    Int      @map("match_score")
  verdict       String
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([clerkUserId])
  @@index([clerkUserId, createdAt])       // ← NEW: "show latest 10 analyses"
  @@map("resume_analyses")
}

model ResumeUsage {
  id          String   @id @default(cuid())
  clerkUserId String   @unique @map("clerk_user_id")
  user        User     @relation(fields: [clerkUserId], references: [id])
  count       Int      @default(0)
  date        DateTime @db.Date    // ← CHANGED: String → DateTime for range queries
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("resume_usage")
}